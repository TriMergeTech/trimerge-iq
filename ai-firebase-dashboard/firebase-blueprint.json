{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile and dashboard state",
      "type": "object",
      "properties": {
        "displayName": { "type": "string", "description": "User's full name" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "photoURL": { "type": "string", "description": "User's profile picture URL" },
        "bio": { "type": "string", "description": "User's short biography" },
        "notes": { "type": "string", "description": "User's personal dashboard notes" }
      },
      "required": ["email"]
    },
    "File": {
      "title": "Uploaded File",
      "description": "Metadata for files uploaded to storage",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Original file name" },
        "url": { "type": "string", "description": "Download URL from Firebase Storage" },
        "type": { "type": "string", "description": "MIME type of the file" },
        "size": { "type": "number", "description": "File size in bytes" },
        "ownerId": { "type": "string", "description": "UID of the user who uploaded the file" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the file was uploaded" }
      },
      "required": ["name", "url", "ownerId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/files/{fileId}": {
      "schema": "File",
      "description": "Metadata for user-uploaded files"
    }
  }
}
