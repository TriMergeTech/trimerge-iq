@page
@model ForgotPasswordModel
@{
    Layout = null;
    ViewData["Title"] = "Forgot Password";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Forgot Password - TriMerge IQ</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        :root {
            --tiq-bg: #eef3fb;
            --tiq-card: #ffffff;
            --tiq-text: #1a2e5a;
            --tiq-muted: #6c87a7;
            --tiq-border: #d7dfeb;
            --tiq-primary: #2d7ef7;
        }

        html, body {
            height: 100%;
        }

        body {
            margin: 0;
            background: var(--tiq-bg);
            font-family: 'Segoe UI', system-ui, sans-serif;
            color: var(--tiq-text);
        }

        .fp-page {
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: flex-start;
            padding: clamp(1.5rem, 5vh, 3.2rem) 1rem 1.5rem;
        }

        .fp-shell {
            width: 100%;
            max-width: 460px;
        }

        .fp-brand {
            text-align: center;
            margin-bottom: 1.1rem;
        }

        .fp-logo {
            width: 54px;
            height: 54px;
            margin: 0 auto 0.6rem;
            display: block;
        }

        .fp-title {
            font-size: clamp(2rem, 6vw, 2.4rem);
            font-weight: 700;
            line-height: 1.1;
            margin: 0;
            color: var(--tiq-text);
        }

        .fp-title span {
            color: var(--tiq-primary);
        }

        .fp-subtitle {
            font-size: 1.08rem;
            color: var(--tiq-muted);
            margin: 0.45rem 0 0;
        }

        .fp-card {
            background: var(--tiq-card);
            border-radius: 18px;
            box-shadow: 0 10px 26px rgba(26, 46, 90, 0.12);
            border: 1px solid #e8eef7;
            padding: 1.45rem 1.3rem 1.35rem;
        }

        .fp-card-title {
            text-align: center;
            font-size: 1.65rem;
            font-weight: 700;
            line-height: 1.15;
            margin: 0 0 1rem;
            color: var(--tiq-text);
        }

        .fp-description {
            text-align: center;
            color: #6f7f99;
            font-size: 1.1rem;
            margin: 0 0 1.25rem;
            line-height: 1.5;
        }

        .fp-form {
            display: grid;
            gap: 0.85rem;
        }

        .fp-field {
            position: relative;
        }

        .fp-input {
            width: 100%;
            height: 50px;
            border-radius: 11px;
            border: 1px solid var(--tiq-border);
            background: #fff;
            padding: 0.65rem 1rem 0.65rem 2.85rem;
            font-size: 1.15rem;
            color: #4a6486;
            outline: none;
            transition: border-color .15s, box-shadow .15s;
        }

        .fp-input::placeholder {
            color: #8a9ab3;
        }

        .fp-input:focus {
            border-color: #8fb8f7;
            box-shadow: 0 0 0 3px rgba(45, 126, 247, 0.15);
        }

        .fp-input-icon {
            position: absolute;
            top: 50%;
            left: 0.9rem;
            transform: translateY(-50%);
            color: #8a9ab3;
            width: 20px;
            height: 20px;
            pointer-events: none;
        }

        .fp-submit {
            margin-top: 0.35rem;
            width: 100%;
            height: 50px;
            border: 0;
            border-radius: 11px;
            background: linear-gradient(90deg, #4f8eea 0%, #2d7ef7 100%);
            color: #fff;
            font-size: 1.18rem;
            font-weight: 700;
            line-height: 1;
            letter-spacing: 0.01em;
            cursor: pointer;
            transition: transform .12s ease, box-shadow .12s ease, opacity .15s ease;
            box-shadow: 0 5px 14px rgba(45, 126, 247, 0.28);
        }

        .fp-submit:hover {
            opacity: 0.95;
        }

        .fp-submit:active {
            transform: translateY(1px);
        }

        .fp-footer {
            margin-top: 1rem;
            padding-top: 1.1rem;
            border-top: 1px solid #e4e9f2;
            text-align: center;
        }

        .fp-footer p {
            margin: 0;
            color: #7b8da8;
            font-size: 1.15rem;
        }

        .fp-footer a {
            color: #2d7ef7;
            font-size: 1.15rem;
            font-weight: 700;
            text-decoration: none;
        }

        .fp-footer a:hover {
            text-decoration: underline;
        }

        @@media (max-width: 480px) {
            .fp-shell {
                max-width: 100%;
            }

            .fp-page {
                padding: 1rem 0.9rem 1.25rem;
            }

            .fp-title {
                font-size: 1.8rem;
            }

            .fp-subtitle {
                font-size: 1rem;
            }

            .fp-card {
                border-radius: 14px;
                padding: 1.1rem 1rem 1.05rem;
            }

            .fp-card-title {
                font-size: 1.4rem;
                margin-bottom: 0.85rem;
            }

            .fp-description {
                font-size: 1rem;
                margin-bottom: 1rem;
            }

            .fp-input {
                height: 46px;
                font-size: 1rem;
            }

            .fp-submit {
                height: 48px;
                font-size: 1.06rem;
            }

            .fp-footer p,
            .fp-footer a {
                font-size: 1rem;
            }
        }
    </style>
</head>
<body>
    <main class="fp-page" role="main">
        <div class="fp-shell">
            <header class="fp-brand" aria-label="TriMerge IQ heading">
                <svg class="fp-logo" viewBox="0 0 52 52" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <rect width="52" height="52" rx="12" fill="#2d7ef7" opacity=".12" />
                    <path d="M14 20 L26 12 L38 20 L38 32 C38 37 32 41 26 44 C20 41 14 37 14 32 Z"
                          fill="#2d7ef7" stroke="#1a5bbf" stroke-width="1.5" />
                    <path d="M21 26 L24.5 30 L31 22" stroke="#fff" stroke-width="2.2"
                          stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                <h1 class="fp-title">TriMerge <span>IQ</span></h1>
                <p class="fp-subtitle">In-House AI Knowledge Tool</p>
            </header>

            <section class="fp-card" aria-label="Forgot password form">
                <h2 class="fp-card-title">Forgot Password</h2>
                <p class="fp-description">Enter your email and we'll send you a password reset link if the account exists in our system.</p>

                <form class="fp-form" method="post" autocomplete="on">
                    <div class="fp-field">
                        <svg class="fp-input-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                            <path d="M3.75 7.75C3.75 6.50736 4.75736 5.5 6 5.5H18C19.2426 5.5 20.25 6.50736 20.25 7.75V16.25C20.25 17.4926 19.2426 18.5 18 18.5H6C4.75736 18.5 3.75 17.4926 3.75 16.25V7.75Z" stroke="currentColor" stroke-width="1.5" />
                            <path d="M4.5 8.25L11.0489 12.616C11.6224 12.9983 12.3776 12.9983 12.9511 12.616L19.5 8.25" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                        <input class="fp-input" id="email" name="email" type="email" placeholder="Email" autocomplete="email" />
                    </div>

                    <button class="fp-submit" type="submit">Send Reset Link</button>
                </form>

                <footer class="fp-footer">
                    <p>Back to <a asp-page="/Login">Log in</a></p>
                </footer>
            </section>
        </div>
    </main>
</body>
</html>
