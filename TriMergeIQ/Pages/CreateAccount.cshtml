@page
@{
    Layout = null;
    ViewData["Title"] = "Create Account";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Create Account - TriMerge IQ</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        :root {
            --tiq-bg: #eef3fb;
            --tiq-card: #ffffff;
            --tiq-text: #1a2e5a;
            --tiq-muted: #6c87a7;
            --tiq-border: #d7dfeb;
            --tiq-primary: #2d7ef7;
            --tiq-primary-dark: #1a5bbf;
        }

        html, body {
            height: 100%;
        }

        body {
            margin: 0;
            background: var(--tiq-bg);
            font-family: 'Segoe UI', system-ui, sans-serif;
            color: var(--tiq-text);
        }

        .ca-page {
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: flex-start;
            padding: clamp(1.5rem, 5vh, 3.2rem) 1rem 1.5rem;
        }

        .ca-shell {
            width: 100%;
            max-width: 460px;
        }

        .ca-brand {
            text-align: center;
            margin-bottom: 1.1rem;
        }

        .ca-logo {
            width: 54px;
            height: 54px;
            margin: 0 auto 0.6rem;
            display: block;
        }

        .ca-title {
            font-size: clamp(2rem, 6vw, 2.4rem);
            font-weight: 700;
            line-height: 1.1;
            margin: 0;
            color: var(--tiq-text);
        }

        .ca-title span {
            color: var(--tiq-primary);
        }

        .ca-subtitle {
            font-size: 1.08rem;
            color: var(--tiq-muted);
            margin: 0.45rem 0 0;
        }

        .ca-card {
            background: var(--tiq-card);
            border-radius: 18px;
            box-shadow: 0 10px 26px rgba(26, 46, 90, 0.12);
            border: 1px solid #e8eef7;
            padding: 1.45rem 1.3rem 1.35rem;
        }

        .ca-card-title {
            text-align: center;
            font-size: 1.65rem;
            font-weight: 700;
            line-height: 1.15;
            margin: 0 0 1.25rem;
            color: var(--tiq-text);
        }

        .ca-form {
            display: grid;
            gap: 0.85rem;
        }

        .ca-field {
            position: relative;
        }

        .ca-field-help {
            margin-top: calc(6px - 0.85rem);
            margin-bottom: calc(14px - 0.85rem);
            color: #6b7280;
            font-size: 12.5px;
            line-height: 1.35;
            padding: 0;
        }

        .ca-input {
            width: 100%;
            height: 50px;
            border-radius: 11px;
            border: 1px solid var(--tiq-border);
            background: #fff;
            padding: 0.65rem 2.8rem 0.65rem 2.85rem;
            font-size: 1.15rem;
            color: #4a6486;
            outline: none;
            transition: border-color .15s, box-shadow .15s;
        }

        .ca-input::placeholder {
            color: #8a9ab3;
        }

        .ca-input:focus {
            border-color: #8fb8f7;
            box-shadow: 0 0 0 3px rgba(45, 126, 247, 0.15);
        }

        .ca-input-icon,
        .ca-toggle-btn {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            color: #8a9ab3;
        }

        .ca-input-icon {
            left: 0.9rem;
            width: 20px;
            height: 20px;
            pointer-events: none;
        }

        .ca-toggle-btn {
            right: 0.55rem;
            border: 0;
            background: transparent;
            width: 34px;
            height: 34px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            cursor: pointer;
        }

        .ca-toggle-btn:hover,
        .ca-toggle-btn:focus-visible {
            background: #edf2fa;
            color: #6c82a1;
            outline: none;
        }

        .ca-submit {
            margin-top: 0.35rem;
            width: 100%;
            height: 50px;
            border: 0;
            border-radius: 11px;
            background: linear-gradient(90deg, #4f8eea 0%, #2d7ef7 100%);
            color: #fff;
            font-size: 1.18rem;
            font-weight: 700;
            line-height: 1;
            letter-spacing: 0.01em;
            cursor: pointer;
            transition: transform .12s ease, box-shadow .12s ease, opacity .15s ease;
            box-shadow: 0 5px 14px rgba(45, 126, 247, 0.28);
        }

        .ca-submit:hover {
            opacity: 0.95;
        }

        .ca-submit:active {
            transform: translateY(1px);
        }

        .ca-footer {
            margin-top: 1.3rem;
            padding-top: 1.1rem;
            border-top: 1px solid #e4e9f2;
            text-align: center;
        }

        .ca-footer p {
            margin: 0;
            color: #7b8da8;
            font-size: 1.15rem;
        }

        .ca-footer a {
            display: inline-block;
            margin-top: 0.3rem;
            color: #2d7ef7;
            font-size: 1.15rem;
            font-weight: 700;
            text-decoration: none;
        }

        .ca-footer a:hover {
            text-decoration: underline;
        }

        @@media (max-width: 480px) {
            .ca-shell {
                max-width: 100%;
            }

            .ca-page {
                padding: 1rem 0.9rem 1.25rem;
            }

            .ca-title {
                font-size: 1.8rem;
            }

            .ca-subtitle {
                font-size: 1rem;
            }

            .ca-card {
                border-radius: 14px;
                padding: 1.1rem 1rem 1.05rem;
            }

            .ca-card-title {
                font-size: 1.4rem;
                margin-bottom: 1rem;
            }

            .ca-input {
                height: 46px;
                font-size: 1rem;
            }

            .ca-field-help { font-size: 12px; }

            .ca-submit {
                height: 48px;
                font-size: 1.06rem;
            }

            .ca-footer p,
            .ca-footer a {
                font-size: 1rem;
            }
        }
    </style>
</head>
<body>
    <main class="ca-page" role="main">
        <div class="ca-shell">
            <header class="ca-brand" aria-label="TriMerge IQ heading">
                <svg class="ca-logo" viewBox="0 0 52 52" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <rect width="52" height="52" rx="12" fill="#2d7ef7" opacity=".12" />
                    <path d="M14 20 L26 12 L38 20 L38 32 C38 37 32 41 26 44 C20 41 14 37 14 32 Z"
                          fill="#2d7ef7" stroke="#1a5bbf" stroke-width="1.5" />
                    <path d="M21 26 L24.5 30 L31 22" stroke="#fff" stroke-width="2.2"
                          stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                <h1 class="ca-title">TriMerge <span>IQ</span></h1>
                <p class="ca-subtitle">In-House AI Knowledge Tool</p>
            </header>

            <section class="ca-card" aria-label="Create account form">
                <h2 class="ca-card-title">Create Account</h2>

                <form class="ca-form" autocomplete="on">
                    <div class="ca-field">
                        <svg class="ca-input-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                            <path d="M12 12.5C14.3472 12.5 16.25 10.5972 16.25 8.25C16.25 5.90279 14.3472 4 12 4C9.65279 4 7.75 5.90279 7.75 8.25C7.75 10.5972 9.65279 12.5 12 12.5Z" fill="currentColor" />
                            <path d="M4 18.5C4 15.7386 7.58172 13.5 12 13.5C16.4183 13.5 20 15.7386 20 18.5V20H4V18.5Z" fill="currentColor" />
                        </svg>
                        <input class="ca-input" id="fullName" name="fullName" type="text" placeholder="Full Name" autocomplete="name" />
                    </div>

                    <div class="ca-field">
                        <svg class="ca-input-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                            <path d="M3.75 7.75C3.75 6.50736 4.75736 5.5 6 5.5H18C19.2426 5.5 20.25 6.50736 20.25 7.75V16.25C20.25 17.4926 19.2426 18.5 18 18.5H6C4.75736 18.5 3.75 17.4926 3.75 16.25V7.75Z" stroke="currentColor" stroke-width="1.5" />
                            <path d="M4.5 8.25L11.0489 12.616C11.6224 12.9983 12.3776 12.9983 12.9511 12.616L19.5 8.25" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                        <input class="ca-input" id="email" name="email" type="email" placeholder="Email" autocomplete="email" />
                    </div>

                    <div class="ca-field">
                        <svg class="ca-input-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                            <rect x="5.25" y="10.25" width="13.5" height="9.5" rx="2" stroke="currentColor" stroke-width="1.5" />
                            <path d="M8.25 10.25V8.25C8.25 6.17893 9.92893 4.5 12 4.5C14.0711 4.5 15.75 6.17893 15.75 8.25V10.25" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                        </svg>
                        <input class="ca-input" id="password" name="password" type="password" placeholder="Password" autocomplete="new-password" aria-describedby="passwordHelp" />
                        <button class="ca-toggle-btn" type="button" data-toggle-password="password" aria-label="Show password">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                <path d="M1.5 12C3.6 7.5 7.35 5.25 12 5.25C16.65 5.25 20.4 7.5 22.5 12C20.4 16.5 16.65 18.75 12 18.75C7.35 18.75 3.6 16.5 1.5 12Z" stroke="currentColor" stroke-width="1.6" />
                                <circle cx="12" cy="12" r="3.25" stroke="currentColor" stroke-width="1.6" />
                            </svg>
                        </button>
                    </div>

                    <p class="ca-field-help" id="passwordHelp">Use 8 or more characters with at least one uppercase letter, one number, and one special character.</p>

                    <div class="ca-field">
                        <svg class="ca-input-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                            <rect x="5.25" y="10.25" width="13.5" height="9.5" rx="2" stroke="currentColor" stroke-width="1.5" />
                            <path d="M8.25 10.25V8.25C8.25 6.17893 9.92893 4.5 12 4.5C14.0711 4.5 15.75 6.17893 15.75 8.25V10.25" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                        </svg>
                        <input class="ca-input" id="confirmPassword" name="confirmPassword" type="password" placeholder="Confirm Password" autocomplete="new-password" />
                        <button class="ca-toggle-btn" type="button" data-toggle-password="confirmPassword" aria-label="Show confirm password">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                                <path d="M1.5 12C3.6 7.5 7.35 5.25 12 5.25C16.65 5.25 20.4 7.5 22.5 12C20.4 16.5 16.65 18.75 12 18.75C7.35 18.75 3.6 16.5 1.5 12Z" stroke="currentColor" stroke-width="1.6" />
                                <circle cx="12" cy="12" r="3.25" stroke="currentColor" stroke-width="1.6" />
                            </svg>
                        </button>
                    </div>

                    <button class="ca-submit" type="submit">Sign up</button>
                </form>

                <footer class="ca-footer">
                    <p>Already have an account?</p>
                    <a asp-page="/Login">Log in</a>
                </footer>
            </section>
        </div>
    </main>

    <script>
        (function () {
            var toggles = document.querySelectorAll('[data-toggle-password]');

            toggles.forEach(function (button) {
                button.addEventListener('click', function () {
                    var inputId = button.getAttribute('data-toggle-password');
                    var input = document.getElementById(inputId);
                    if (!input) {
                        return;
                    }

                    var isPassword = input.type === 'password';
                    input.type = isPassword ? 'text' : 'password';
                    button.setAttribute('aria-label', isPassword ? 'Hide password' : 'Show password');
                });
            });
        })();
    </script>
</body>
</html>
