@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

<style>
    /* Page shell */
    .tiq-page {
        background: #eef3fb;
        min-height: 100vh;
        padding: 0 0 2.6rem;
        font-family: 'Segoe UI', system-ui, sans-serif;
    }

    .tiq-page-inner {
        max-width: 920px;
        margin: 0 auto;
        padding: 0 1rem;
    }

    /* Logo header */
    .tiq-logo-row {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.4rem;
        margin-bottom: 0;
    }

    .tiq-brand-section {
        background: #fff;
        padding: 1.4rem 0 1rem;
        margin: 0 0 1rem;
    }

    .tiq-brand-divider {
        width: min(520px, 88%);
        height: 2px;
        background: #d6e9fa;
        border-radius: 999px;
        margin: 0.5rem auto 0.7rem;
    }

    .tiq-logo-row svg { width: 60px; height: 60px; }

    .tiq-brand {
        font-size: clamp(2.35rem, 4.25vw, 3.3rem);
        font-weight: 700;
        color: #1a2e5a;
        margin: 0;
        line-height: 1;
    }

    .tiq-brand span { color: #2d7ef7; }

    .tiq-tagline {
        color: #1a2e5a;
        font-size: clamp(1rem, 1.5vw, 1.18rem);
        font-weight: 700;
        margin: 0;
    }

    /* Section heading */
    .tiq-section-heading {
        text-align: center;
        font-size: clamp(1.35rem, 2.4vw, 1.9rem);
        font-weight: 700;
        color: #1a2e5a;
        margin-bottom: 1.3rem;
        padding: 0.6rem 0;
    }

    /* Feature grid */
    .tiq-card-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 0.9rem;
        max-width: 900px;
        margin: 0 auto 1.75rem;
    }

    @@media (max-width: 560px) {
        .tiq-card-grid { grid-template-columns: 1fr; }
    }

    .tiq-card {
        background: #fff;
        border-radius: 12px;
        border: 1px solid #d5e0ed;
        padding: 1rem 1.05rem;
        display: flex;
        align-items: center;
        gap: 0.8rem;
        min-height: 128px;
        box-shadow: 0 2px 6px rgba(30, 59, 95, 0.12);
    }

    .tiq-card-icon {
        flex-shrink: 0;
        width: 92px;
        height: 80px;
        border-radius: 0;
        background: transparent;
        display: grid;
        place-items: center;
    }

    .tiq-card-icon svg {
        width: 84px;
        height: 74px;
    }

    .tiq-card-text h3 {
        font-size: clamp(1.12rem, 1.55vw, 1.35rem);
        font-weight: 700;
        color: #1a2e5a;
        margin: 0 0 0.3rem;
        line-height: 1.15;
    }

    .tiq-card-text p {
        font-size: clamp(0.95rem, 1.2vw, 1.02rem);
        color: #555;
        margin: 0;
        line-height: 1.28;
    }

    /* Hero illustration */
    .tiq-hero {
        max-width: 900px;
        margin: 0 auto 1.75rem;
        background: #dce8fb;
        border-radius: 18px;
        padding: 0.1rem 0.7rem;
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: clamp(140px, 16vw, 190px);
        overflow: hidden;
    }

    .tiq-hero img {
        width: 100%;
        height: 100%;
        display: block;
        border-radius: 14px;
           object-fit: cover;
            object-position: center;
    }

    /* CTA buttons */
    .tiq-cta-row {
        display: flex;
        gap: 0.85rem;
        justify-content: center;
        flex-wrap: wrap;
        max-width: 900px;
        margin: 0 auto;
    }

    .tiq-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.9rem 2rem;
        border-radius: 10px;
        font-size: clamp(1rem, 1.3vw, 1.12rem);
        font-weight: 700;
        text-decoration: none;
        transition: opacity .15s;
        min-width: 280px;
        justify-content: center;
    }

    @@media (max-width: 1024px) {
        .tiq-card-grid,
        .tiq-hero,
        .tiq-cta-row { max-width: 860px; }
        .tiq-btn {
            min-width: 250px;
        }
    }

    @@media (max-width: 640px) {
        .tiq-brand { font-size: 2.1rem; }
        .tiq-tagline { font-size: 1rem; }
        .tiq-section-heading { font-size: 1.35rem; }
        .tiq-card {
            min-height: 118px;
            padding: 0.9rem;
            gap: 0.7rem;
        }
        .tiq-card-icon {
            width: 74px;
            height: 64px;
        }
        .tiq-card-icon svg {
            width: 64px;
            height: 56px;
        }
        .tiq-card-text h3 { font-size: 1rem; }
        .tiq-card-text p { font-size: 0.9rem; }
        .tiq-btn {
            min-width: 100%;
            font-size: 1rem;
            padding: 0.85rem 1.2rem;
        }
    }

    .tiq-btn:hover { opacity: .85; }

    .tiq-btn-primary {
        background: #2d7ef7;
        color: #fff;
        border: 2px solid #2d7ef7;
    }

    .tiq-btn-outline {
        background: #fff;
        color: #1a2e5a;
        border: 2px solid #c8d5e8;
    }
</style>

<div class="tiq-page">

    <!-- Logo & tagline -->
    <div class="tiq-brand-section">
        <div class="tiq-page-inner">
            <div class="tiq-logo-row">
                <svg viewBox="0 0 52 52" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <rect width="52" height="52" rx="12" fill="#2d7ef7" opacity=".12"/>
                    <path d="M14 20 L26 12 L38 20 L38 32 C38 37 32 41 26 44 C20 41 14 37 14 32 Z"
                          fill="#2d7ef7" stroke="#1a5bbf" stroke-width="1.5"/>
                    <path d="M21 26 L24.5 30 L31 22" stroke="#fff" stroke-width="2.2"
                          stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <h1 class="tiq-brand">TriMerge <span>IQ</span></h1>
                <div class="tiq-brand-divider" aria-hidden="true"></div>
                <p class="tiq-tagline">In-House AI Knowledge Tool</p>
            </div>
        </div>
    </div>

<div class="tiq-page-inner">

    <!-- Section heading -->
    <p class="tiq-section-heading">Private &amp; Secure AI Assistant for TriMerge</p>

    <!-- Feature cards -->
    <section class="tiq-card-grid" aria-label="Features">

        <article class="tiq-card">
            <div class="tiq-card-icon">
                <svg viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <path d="M5 9.5 L14 4 L23 9.5 L23 18C23 22.2 18.5 25.5 14 27.5C9.5 25.5 5 22.2 5 18 Z"
                          fill="#2d7ef7" opacity=".2" stroke="#2d7ef7" stroke-width="1.5"/>
                    <path d="M10 14.5 L12.8 17.5 L18 11" stroke="#2d7ef7" stroke-width="2"
                          stroke-linecap="round" stroke-linejoin="round"/>
                    <circle cx="20" cy="6" r="4" fill="#34c759"/>
                    <path d="M18.5 6 L19.5 7 L21.5 5" stroke="#fff" stroke-width="1.4"
                          stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </div>
            <div class="tiq-card-text">
                <h3>Confidential &amp; In-House AI</h3>
                <p>Your data never leaves TriMerge</p>
            </div>
        </article>

        <article class="tiq-card">
            <div class="tiq-card-icon">
                <svg viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <rect x="4" y="3" width="14" height="18" rx="2" fill="#2d7ef7" opacity=".2" stroke="#2d7ef7" stroke-width="1.5"/>
                    <rect x="8" y="6.5" width="8" height="1.5" rx="0.75" fill="#2d7ef7"/>
                    <rect x="8" y="10" width="6" height="1.5" rx="0.75" fill="#2d7ef7"/>
                    <rect x="8" y="13.5" width="7" height="1.5" rx="0.75" fill="#2d7ef7"/>
                    <circle cx="20" cy="20" r="4" fill="#fff" stroke="#2d7ef7" stroke-width="1.5"/>
                    <line x1="23" y1="23" x2="25.5" y2="25.5" stroke="#2d7ef7" stroke-width="1.8" stroke-linecap="round"/>
                </svg>
            </div>
            <div class="tiq-card-text">
                <h3>Knowledge Search</h3>
                <p>Find any document or policy</p>
            </div>
        </article>

        <article class="tiq-card">
            <div class="tiq-card-icon">
                <svg viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <rect x="3" y="4" width="16" height="11" rx="3" fill="#2d7ef7" opacity=".25" stroke="#2d7ef7" stroke-width="1.5"/>
                    <circle cx="7.5" cy="9.5" r="1.2" fill="#2d7ef7"/>
                    <circle cx="11" cy="9.5" r="1.2" fill="#2d7ef7"/>
                    <circle cx="14.5" cy="9.5" r="1.2" fill="#2d7ef7"/>
                    <rect x="9" y="12" width="16" height="11" rx="3" fill="#2d7ef7" opacity=".5" stroke="#2d7ef7" stroke-width="1.5"/>
                    <circle cx="13.5" cy="17.5" r="1.2" fill="#fff"/>
                    <circle cx="17" cy="17.5" r="1.2" fill="#fff"/>
                    <circle cx="20.5" cy="17.5" r="1.2" fill="#fff"/>
                </svg>
            </div>
            <div class="tiq-card-text">
                <h3>Process Q&amp;A</h3>
                <p>Ask about procedures &amp; clients</p>
            </div>
        </article>

        <article class="tiq-card">
            <div class="tiq-card-icon">
                <svg viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <rect x="4" y="3" width="14" height="18" rx="2" fill="#2d7ef7" opacity=".2" stroke="#2d7ef7" stroke-width="1.5"/>
                    <rect x="7" y="7" width="8" height="1.5" rx="0.75" fill="#2d7ef7"/>
                    <rect x="7" y="10.5" width="6" height="1.5" rx="0.75" fill="#2d7ef7"/>
                    <rect x="7" y="14" width="7" height="1.5" rx="0.75" fill="#2d7ef7"/>
                    <path d="M18 17 L23 12 L26 15 L21 20 L17 21 Z" fill="#2d7ef7" stroke="#1a5bbf" stroke-width="1.2" stroke-linejoin="round"/>
                    <line x1="21" y1="13" x2="24" y2="16" stroke="#fff" stroke-width="1"/>
                </svg>
            </div>
            <div class="tiq-card-text">
                <h3>Content Drafting</h3>
                <p>Generate proposals &amp; reports</p>
            </div>
        </article>

    </section>

    <!-- Hero illustration -->
    <div class="tiq-hero" aria-label="Illustration of a person using TriMerge IQ">
        <img src="~/images/hero-illustration.png"
             alt="Person using TriMerge IQ at a computer with AI chat" />
    </div>

    <!-- CTA buttons -->
    <nav class="tiq-cta-row" aria-label="Primary actions">
        <a class="tiq-btn tiq-btn-primary" asp-page="/CreateAccount">
            Sign up
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8H13M9 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </a>
        <a class="tiq-btn tiq-btn-outline" asp-page="/Login">
            Log in
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M3 8H13M9 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </a>
    </nav>

</div>
</div>
